# Base URL for API requests (optional). For local Spring Boot use http://localhost:8081
VITE_API_BASE_URL=http://localhost:8081

# Auth API path prefix
VITE_AUTH_API_PATH=/api/auth

# Dubbing API path prefix
VITE_DUBBING_API_PATH=/api/dubbing

# Enable frontend-only mock auth when backend is unavailable.
# In local development this is auto-enabled if VITE_API_BASE_URL is empty.
VITE_ENABLE_AUTH_MOCK=false
